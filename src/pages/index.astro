---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import { getBlogPermalink, getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Home',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    id="home"
    tagline="Academic Blog"
    actions={[
      {
        variant: 'primary',
        text: '进入博客',
        href: getBlogPermalink(),
      },
      {
        text: '查看 Research',
        href: getPermalink('/research'),
      },
    ]}
  >
    <Fragment slot="title">
      一个简洁的个人主页，用来记录
      <span class="text-accent dark:text-white">研究</span>、<span class="text-accent dark:text-white">学习</span>与
      <span class="text-accent dark:text-white">思考</span>
    </Fragment>

    <Fragment slot="subtitle">
      这里主要放研究笔记、理论学习过程、阶段性总结与一些较慢的个人思考。整体风格尽量克制，让内容本身成为页面的重点。
    </Fragment>
  </Hero>

  <Features2
    id="columns"
    tagline="Columns"
    title="主要专栏"
    subtitle="先用几个稳定栏目组织内容，后续可以继续细分。"
    items={[
      {
        title: '研究笔记',
        description: '记录论文阅读、问题拆解、方法比较，以及还没有完全想清楚但值得继续追踪的想法。',
        icon: 'tabler:notebook',
      },
      {
        title: '理论学习',
        description: '系统整理基础概念、关键定理、方法脉络与个人理解，适合长期迭代与反复回看。',
        icon: 'tabler:books',
      },
      {
        title: '思考随笔',
        description: '保留一些不完全学术化的写作空间，用来整理阅读后的联想、方法论判断与阶段性反思。',
        icon: 'tabler:bulb',
      },
    ]}
  />

  <Content
    id="about"
    tagline="About"
    title="把它当作你的线上研究档案"
    items={[
      {
        title: '持续积累',
        description: '把分散的笔记、阅读摘录和零散想法沉淀成可以检索、可以回顾、可以继续扩展的文章。',
      },
      {
        title: '结构清晰',
        description: '用首页、博客与研究页面区分不同类型的信息，让读者快速理解你的关注方向与写作重点。',
      },
      {
        title: '面向长期写作',
        description: '设计不追求花哨，而是优先保证可读性、可维护性，以及后续扩充内容时的稳定性。',
      },
    ]}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">现在这个版本更适合学术博客场景</h2>
      <p>
        首页负责说明你是谁、你在做什么，以及最近在关注什么问题；博客页负责按时间流与分类组织文章；`Research`
        页面则更适合承载研究方向、项目计划、论文清单与未来工作。
      </p>
      <br />
      <p>
        当前先提供一套通用骨架。后续你只需要把姓名、简介、方向、论文和文章内容替换成自己的，就能很快变成个人学术主页。
      </p>
    </Fragment>
  </Content>

  <Steps
    id="focus"
    title="当前适合放在首页的信息"
    subtitle="相比营销型模板，这里更适合展示稳定、低噪声、能帮助读者快速理解你的内容。"
    items={[
      {
        title: '个人简介',
        description: '简短介绍你的研究背景、当前方向、所属院校或实验室，以及这个网站的写作目标。',
        icon: 'tabler:user',
      },
      {
        title: '近期关注的问题',
        description: '用 2 到 4 个主题概括最近的研究或学习重点，例如生成模型、优化理论、具身智能等。',
        icon: 'tabler:focus-2',
      },
      {
        title: '最新文章',
        description: '首页底部直接展示最近几篇文章，方便读者快速进入你当前的写作脉络。',
        icon: 'tabler:article',
      },
      {
        title: '研究页面',
        description: '把更长期的信息放进独立页面，例如论文、项目、计划、课程笔记与未来工作。',
        icon: 'tabler:flask-2',
      },
    ]}
  />

  <BlogLatestPosts
    title="最新文章"
    linkText="查看全部文章"
    information="这里展示最近更新的研究笔记、理论学习与思考随笔。后续你只需要持续写作，首页就会自动同步最新内容。"
  />
</Layout>
