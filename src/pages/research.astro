---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import { getBlogPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Research',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Research"
    actions={[
      {
        variant: 'primary',
        text: '查看博客文章',
        href: getBlogPermalink(),
      },
    ]}
  >
    <Fragment slot="title">研究方向与长期计划</Fragment>
    <Fragment slot="subtitle">
      这个页面用于承载比博客更稳定的内容，例如研究兴趣、项目计划、阅读路径、阶段目标，以及未来准备持续推进的问题。
    </Fragment>
  </Hero>

  <Features3
    title="研究兴趣"
    subtitle="下面先放一组通用的学术主页占位内容，后续可以直接替换成你的真实方向。"
    columns={3}
    defaultIcon="tabler:point-filled"
    items={[
      {
        title: '生成模型',
        description: '关注扩散模型、Flow Matching、表征学习，以及生成方法与下游任务的结合方式。',
      },
      {
        title: '理论学习',
        description: '整理概率建模、优化方法、统计学习与几何直觉之间的联系，尽量形成长期可复用的知识框架。',
      },
      {
        title: '研究方法',
        description: '记录做问题拆解、读论文、搭实验、归纳失败经验时形成的一些工作流与判断标准。',
      },
    ]}
  />

  <Content
    title="这个页面建议长期维护哪些内容？"
    items={[
      {
        title: '项目与课题',
        description: '可以写正在做或准备做的课题、项目动机、当前进展，以及后续想验证的方向。',
      },
      {
        title: '论文与阅读清单',
        description: '适合列出代表性论文、阅读路线和每个方向的关键问题，方便自己和读者快速定位。',
      },
      {
        title: '公开资料',
        description: '如果后续有报告、讲义、代码仓库、海报或课程笔记，也可以统一收在这里。',
      },
    ]}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Research 页面更像一份稳定简历</h2>
      <p>
        与按时间更新的博客不同，这里更适合承载那些不会频繁改变、但又能代表你研究脉络的内容。这样首页保持简洁，博客保持流动，研究页保持稳定。
      </p>
    </Fragment>
  </Content>

  <Steps
    title="可以逐步补充的信息"
    items={[
      {
        title: '阶段一：补全个人信息',
        description: '姓名、学校/实验室、研究方向、一段简短自我介绍。',
        icon: 'tabler:user-circle',
      },
      {
        title: '阶段二：整理研究主题',
        description: '把当前长期关注的问题拆成 2 到 4 个主题，每个主题配上 1 到 2 句说明。',
        icon: 'tabler:hierarchy-2',
      },
      {
        title: '阶段三：补论文与项目',
        description: '如果有论文、课程项目、开源仓库或演讲材料，可以持续往这里补充。',
        icon: 'tabler:file-description',
      },
      {
        title: '阶段四：保持同步',
        description: '当博客里形成更成熟的文章后，再把其中一部分沉淀回这个 Research 页面。',
        icon: 'tabler:refresh',
      },
    ]}
  />
</Layout>
