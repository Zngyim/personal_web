---
import Layout from '~/layouts/PageLayout.astro';
import { getBlogPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Research',
};
---

<Layout metadata={metadata}>
  <div class="max-w-3xl mx-auto px-4 min-h-[72vh] flex items-start justify-center pt-[18vh] pb-24 md:pt-[22vh] md:pb-32">
    <section class="text-center">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-page dark:text-white mb-5">Research</h1>
      <p class="text-base md:text-lg leading-8 text-muted dark:text-slate-400 max-w-2xl mx-auto">
        Research interests and ongoing work will be added here in the future.
      </p>
      <p class="mt-8">
        <a class="text-sm text-primary hover:underline" href={getBlogPermalink()}>Go to Blog</a>
      </p>
    </section>
  </div>
</Layout>
