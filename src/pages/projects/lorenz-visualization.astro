---
import Layout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';
import lorenzVisualizationHtml from '../../../lorenz_visualization.html?raw';
import { projects } from '~/data/projects';

const metadata = {
  title: 'Lorenz 吸引子可视化',
};

const project = projects.find((item) => item.slug === 'lorenz-visualization');
---

<Layout metadata={metadata}>
  <Fragment slot="footer"></Fragment>
  <div class="w-full">
    <div class="border-b border-gray-200 dark:border-slate-800 px-4 py-3 text-sm text-muted dark:text-slate-400">
      <div class="max-w-7xl mx-auto">
        <a class="hover:underline" href={getPermalink('/projects')}>Project</a> / {project?.title ?? 'Lorenz 吸引子可视化'}
      </div>
    </div>
    <iframe
      title="Lorenz 吸引子可视化"
      srcdoc={lorenzVisualizationHtml}
      class="block w-full h-[calc(100vh-121px)] min-h-[calc(100vh-121px)] bg-white"
    />
  </div>
</Layout>
