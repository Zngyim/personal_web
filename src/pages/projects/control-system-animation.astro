---
import Layout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';
import controlSystemAnimationHtml from '../../../control-system-animation.html?raw';
import { projects } from '~/data/projects';

const metadata = {
  title: '自动控制原理框图',
};

const project = projects.find((item) => item.slug === 'control-system-animation');
---

<Layout metadata={metadata}>
  <div class="max-w-6xl mx-auto px-4 py-10 md:py-14">
    <section class="max-w-3xl mb-8">
      <p class="text-sm text-muted dark:text-slate-400 mb-3">
        <a class="hover:underline" href={getPermalink('/projects')}>Project</a> / {project?.title ?? '自动控制原理框图'}
      </p>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-page dark:text-white mb-4">
        {project?.title ?? '自动控制原理框图'}
      </h1>
      <p class="text-base md:text-lg leading-8 text-page dark:text-slate-200">
        {project?.description ?? '在这里填写这个项目的简短介绍。'}
      </p>
    </section>

    <section class="rounded-md border border-gray-200 dark:border-slate-800 overflow-hidden">
      <iframe
        title="自动控制原理框图"
        srcdoc={controlSystemAnimationHtml}
        class="w-full h-[1600px] bg-white"
      />
    </section>
  </div>
</Layout>
