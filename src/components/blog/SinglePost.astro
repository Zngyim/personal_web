---
import PostTags from '~/components/blog/Tags.astro';
import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post } = Astro.props;
const tocHeadings = (post.headings || []).filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<section class="py-8 md:py-12 mx-auto">
  <article class="max-w-6xl mx-auto px-4">
    <div class="lg:grid lg:grid-cols-[minmax(0,44rem)_16rem] lg:gap-12">
      <div>
        <header class="max-w-2xl">
      <div class="text-sm text-muted dark:text-slate-400 mb-3">
        <p>
          <time datetime={String(post.publishDate)} class="inline-block">{getFormattedDate(post.publishDate)}</time>
          {
            post.author && (
              <>
                {' '}
                <span class="inline-block">{post.author}</span>
              </>
            )
          }
          {
            post.category && (
              <>
                {' '}
                ·{' '}
                <a class="hover:underline inline-block" href={getPermalink(post.category.slug, 'category')}>
                  {post.category.title}
                </a>
              </>
            )
          }
          {
            post.readingTime && (
              <>
                &nbsp;· <span>{post.readingTime}</span> 分钟阅读
              </>
            )
          }
        </p>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold leading-tight tracking-tight text-page dark:text-white">{post.title}</h1>
      {post.excerpt && <p class="mt-4 text-base leading-7 text-muted dark:text-slate-400">{post.excerpt}</p>}
        </header>
        <div
          class="max-w-2xl prose prose-base leading-8 font-serif dark:prose-invert prose-headings:text-page dark:prose-headings:text-white prose-headings:font-serif prose-a:text-primary dark:prose-a:text-blue-400 prose-img:rounded-sm prose-img:shadow-none mt-10 prose-headings:scroll-mt-[80px] prose-li:my-1"
        >
          <slot />
        </div>
        <div class="max-w-2xl mt-10">
          <PostTags tags={post.tags} />
        </div>
      </div>

      {
        tocHeadings.length > 0 && (
          <aside class="hidden lg:block">
            <div class="sticky top-24 border-l border-gray-200 dark:border-slate-800 pl-6">
              <h2 class="text-sm font-semibold tracking-wide uppercase text-page dark:text-white mb-4">目录</h2>
              <nav aria-label="文章目录">
                <ul class="space-y-3 text-sm text-muted dark:text-slate-400">
                  {tocHeadings.map((heading) => (
                    <li class:list={[heading.depth === 3 ? 'ml-4' : 'ml-0']}>
                      <a
                        class="block border-l-2 border-transparent pl-3 transition-colors hover:text-page hover:underline dark:hover:text-white"
                        data-toc-link={heading.slug}
                        href={`#${heading.slug}`}
                      >
                        {heading.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          </aside>
        )
      }
    </div>
  </article>
</section>

<script is:inline>
  (() => {
    const setupActiveToc = () => {
      const tocLinks = Array.from(document.querySelectorAll('[data-toc-link]'));
      if (!tocLinks.length) return;

      const headings = tocLinks
        .map((link) => {
          const slug = link.getAttribute('data-toc-link');
          if (!slug) return null;
          const element = document.getElementById(slug);
          return element ? { slug, element, link } : null;
        })
        .filter(Boolean);

      if (!headings.length) return;

      const setActive = (activeSlug) => {
        headings.forEach(({ slug, link }) => {
          const isActive = slug === activeSlug;
          link.classList.toggle('text-page', isActive);
          link.classList.toggle('dark:text-white', isActive);
          link.classList.toggle('font-semibold', isActive);
          link.classList.toggle('border-gray-400', isActive);
          link.classList.toggle('dark:border-slate-500', isActive);

          link.classList.toggle('text-muted', !isActive);
          link.classList.toggle('dark:text-slate-400', !isActive);
        });
      };

      setActive(headings[0].slug);

      const observer = new IntersectionObserver(
        (entries) => {
          const visibleHeadings = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

          if (!visibleHeadings.length) return;

          setActive(visibleHeadings[0].target.id);
        },
        {
          rootMargin: '-20% 0px -65% 0px',
          threshold: [0, 1],
        }
      );

      headings.forEach(({ element }) => observer.observe(element));

      if (window.__awBlogTocObserver) {
        window.__awBlogTocObserver.disconnect();
      }
      window.__awBlogTocObserver = observer;
    };

    document.addEventListener('astro:page-load', setupActiveToc);
    setupActiveToc();
  })();
</script>
